rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cho phép bất kỳ ai đọc lời chúc
    // Cho phép tạo lời chúc mới
    // Không cho phép xóa hoặc chỉnh sửa để bảo vệ nội dung
    match /wishes/{wishId} {
      allow read: if true;
      allow create: if request.resource.data.name != "" && request.resource.data.message != "";
      allow update, delete: if false;
    }

    // Quản lý khách mời & Tracking
    match /guest_links/{linkId} {
      allow read, create, delete: if true;
      // Cho phép khách mời cập nhật lượt xem, nhưng không cho sửa tên/link
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['viewCount', 'lastViewedAt']);
    }
  }
}
